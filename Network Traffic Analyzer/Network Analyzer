# ── Packet Analysis Engine ─────────────────────────────────────────────────────

class NetworkAnalyzer:
    """
    Core packet analysis engine.
    
    Architecture: Event-driven packet processing pipeline.
    Each captured packet flows through multiple detection modules.
    Statistics are aggregated in real-time in thread-safe counters.
    
    Detection modules:
    1. Protocol breakdown
    2. Port scan detection (SYN flood, rapid connection attempts)
    3. DNS analysis (query tracking, DGA detection, tunneling detection)
    4. ARP analysis (ARP spoofing / poisoning)
    5. HTTP/HTTPS analysis (plaintext credentials, suspicious user agents)
    6. Large data transfer / exfiltration detection
    7. Suspicious port detection
    8. Connection tracking
    """
    
    def __init__(self):
        # ── Packet counters ────────────────────────────────────────────────
        self.total_packets = 0
        self.packet_lock = threading.Lock()
        
        # Protocol counters
        self.protocol_counts = collections.Counter()
        
        # ── Connection tracking ────────────────────────────────────────────
        # Format: {(src_ip, dst_ip, dst_port): [timestamps]}
        self.connections = collections.defaultdict(list)
        
        # Bytes transferred per host
        self.bytes_per_src = collections.defaultdict(int)
        self.bytes_per_dst = collections.defaultdict(int)
        
        # ── Port scan detection ────────────────────────────────────────────
        # Tracks unique ports contacted per source IP
        # {src_ip: {dst_ip: set(ports)}}
        self.port_scan_tracker = collections.defaultdict(
            lambda: collections.defaultdict(set)
        )
        # Port scan alerts already fired (to avoid duplicates)
        self.port_scan_alerts_fired = set()
        
        # SYN flood tracker: {dst_ip: [timestamps of SYN packets]}
        self.syn_flood_tracker = collections.defaultdict(list)
        
        # ── DNS analysis ───────────────────────────────────────────────────
        self.dns_queries = []           # All DNS queries
        self.dns_query_counts = collections.Counter()  # Domain → count
        self.dns_responses = {}         # Query → response IP mapping
        self.suspicious_dns = []        # Flagged queries
        
        # DNS tunneling detector: tracks query lengths
        # Legitimate DNS queries are short; DNS tunnel queries are very long
        self.dns_lengths = []
        
        # ── ARP analysis ───────────────────────────────────────────────────
        # {IP: [list of MACs claiming to own it]}
        self.arp_table = collections.defaultdict(set)
        self.arp_conflicts = []
        
        # ── HTTP analysis ─────────────────────────────────────────────────
        self.http_requests = []
        self.suspicious_http = []
        
        # ── Alerts ────────────────────────────────────────────────────────
        self.alerts = []
        
        # ── Timing ────────────────────────────────────────────────────────
        self.start_time = time.time()
        self.first_packet_time = None
        self.last_packet_time = None
    
    def add_alert(self, level: str, category: str, message: str, evidence: dict = None):
        """
        Add a security alert. Levels: CRITICAL, HIGH, MEDIUM, LOW, INFO
        """
        alert = {
            'timestamp': datetime.datetime.utcnow().isoformat() + 'Z',
            'level':     level,
            'category':  category,
            'message':   message,
            'evidence':  evidence or {},
        }
        self.alerts.append(alert)
        
        # Real-time console output
        icons = {'CRITICAL': '🚨', 'HIGH': '❌', 'MEDIUM': '⚠️ ', 'LOW': '⚡', 'INFO': 'ℹ️ '}
        icon = icons.get(level, '•')
        print(f'  {icon} [{level}] {category}: {message}')
    
    def process_packet(self, pkt):
        """
        Main packet processing callback — called for every captured packet.
        Routes to appropriate analysis modules.
        """
        with self.packet_lock:
            self.total_packets += 1
        
        current_time = time.time()
        self.last_packet_time = current_time
        if self.first_packet_time is None:
            self.first_packet_time = current_time
        
        pkt_len = len(pkt)
        
        # ── ARP analysis (Layer 2) ─────────────────────────────────────────
        if ARP and pkt.haslayer(ARP):
            self._analyze_arp(pkt)
        
        # ── IP layer analysis ──────────────────────────────────────────────
        if IP and pkt.haslayer(IP):
            self._analyze_ip_packet(pkt, current_time, pkt_len)
        
        # IPv6 (basic tracking)
        elif IPv6 and pkt.haslayer(IPv6):
            self.protocol_counts['IPv6'] += 1
    
    def _analyze_ip_packet(self, pkt, current_time: float, pkt_len: int):
        """Analyze an IP-layer packet."""
        ip = pkt[IP]
        src_ip = ip.src
        dst_ip = ip.dst
        
        # Track bytes per host
        self.bytes_per_src[src_ip] += pkt_len
        self.bytes_per_dst[dst_ip] += pkt_len
        
        # ── TCP analysis ───────────────────────────────────────────────────
        if TCP and pkt.haslayer(TCP):
            self._analyze_tcp(pkt, ip, current_time)
        
        # ── UDP analysis ───────────────────────────────────────────────────
        elif UDP and pkt.haslayer(UDP):
            self._analyze_udp(pkt, ip, pkt_len)
        
        # ── ICMP analysis ──────────────────────────────────────────────────
        elif ICMP and pkt.haslayer(ICMP):
            self._analyze_icmp(pkt, ip)
    
    def _analyze_tcp(self, pkt, ip, current_time: float):
        """TCP packet analysis: port scans, SYN floods, HTTP, suspicious ports."""
        tcp = pkt[TCP]
        src_ip = ip.src
        dst_ip = ip.dst
        dst_port = tcp.dport
        src_port = tcp.sport
        flags = tcp.flags
        
        self.protocol_counts['TCP'] += 1
        
        # ── Port scan detection ────────────────────────────────────────────
        # Track ports each source is connecting to on each destination
        self.port_scan_tracker[src_ip][dst_ip].add(dst_port)
        
        ports_tried = len(self.port_scan_tracker[src_ip][dst_ip])
        scan_key = (src_ip, dst_ip)
        
        # Threshold: 15+ unique ports in one scan session = port scan
        if ports_tried >= 15 and scan_key not in self.port_scan_alerts_fired:
            self.port_scan_alerts_fired.add(scan_key)
            self.add_alert(
                'HIGH', 'PORT_SCAN',
                f'{src_ip} → {dst_ip}: scanned {ports_tried}+ ports',
                {'source': src_ip, 'target': dst_ip, 'ports_scanned': ports_tried,
                 'sample_ports': sorted(list(self.port_scan_tracker[src_ip][dst_ip]))[:20]}
            )
        
        # ── SYN flood detection ────────────────────────────────────────────
        # A SYN flood sends many SYN packets without completing the handshake
        # This exhausts server connection tables (DoS)
        if flags & 0x02 and not (flags & 0x10):  # SYN set, ACK not set
            self.syn_flood_tracker[dst_ip].append(current_time)
            
            # Clean old entries (keep only last 10 seconds)
            self.syn_flood_tracker[dst_ip] = [
                t for t in self.syn_flood_tracker[dst_ip]
                if current_time - t < 10
            ]
            
            # Alert if >100 SYNs in 10 seconds to same destination
            syn_count = len(self.syn_flood_tracker[dst_ip])
            if syn_count > 100:
                self.add_alert(
                    'CRITICAL', 'SYN_FLOOD',
                    f'Possible SYN flood targeting {dst_ip}: {syn_count} SYNs in 10s',
                    {'target': dst_ip, 'syn_count': syn_count}
                )
        
        # ── Suspicious port check ──────────────────────────────────────────
        for port in [dst_port, src_port]:
            if port in SUSPICIOUS_PORTS:
                self.add_alert(
                    'MEDIUM', 'SUSPICIOUS_PORT',
                    f'{src_ip}:{src_port} → {dst_ip}:{dst_port} — {SUSPICIOUS_PORTS[port]}',
                    {'src': src_ip, 'dst': dst_ip, 'port': port,
                     'description': SUSPICIOUS_PORTS[port]}
                )
        
        # ── Telnet detection ───────────────────────────────────────────────
        # Telnet sends credentials in plaintext — should never be used
        if dst_port == 23 or src_port == 23:
            self.add_alert(
                'HIGH', 'PLAINTEXT_PROTOCOL',
                f'Telnet traffic detected: {src_ip} → {dst_ip}',
                {'src': src_ip, 'dst': dst_ip, 'protocol': 'Telnet'}
            )
        
        # ── HTTP (unencrypted) on port 80 ─────────────────────────────────
        if (dst_port == 80 or src_port == 80) and pkt.haslayer(Raw):
            self._analyze_http(pkt, src_ip, dst_ip)
        
        # Track connection
        conn_key = (src_ip, dst_ip, dst_port)
        self.connections[conn_key].append(current_time)
    
    def _analyze_udp(self, pkt, ip, pkt_len: int):
        """UDP analysis: DNS, large transfers."""
        udp = pkt[UDP]
        src_ip = ip.src
        dst_ip = ip.dst
        dst_port = udp.dport
        
        self.protocol_counts['UDP'] += 1
        
        # ── DNS analysis ───────────────────────────────────────────────────
        if DNS and pkt.haslayer(DNS):
            self._analyze_dns(pkt, src_ip, dst_ip)
        
        # ── Large UDP datagrams ────────────────────────────────────────────
        # Could indicate DNS tunneling or UDP-based exfiltration
        if pkt_len > 512 and dst_port == 53:
            self.add_alert(
                'LOW', 'LARGE_DNS_PACKET',
                f'Oversized DNS packet from {src_ip}: {pkt_len} bytes',
                {'src': src_ip, 'size': pkt_len}
            )
    
    def _analyze_icmp(self, pkt, ip):
        """ICMP analysis: ICMP tunneling, ping sweeps."""
        self.protocol_counts['ICMP'] += 1
        
        icmp = pkt[ICMP]
        src_ip = ip.src
        
        # ── ICMP tunneling ─────────────────────────────────────────────────
        # Normal ICMP echo payload is 48 bytes or less
        # Attackers use oversized ICMP payloads to tunnel data
        if pkt.haslayer(Raw):
            payload = bytes(pkt[Raw])
            if len(payload) > 64:
                self.add_alert(
                    'MEDIUM', 'ICMP_TUNNEL',
                    f'Oversized ICMP payload from {src_ip}: {len(payload)} bytes',
                    {'src': src_ip, 'payload_size': len(payload)}
                )
    
    def _analyze_dns(self, pkt, src_ip: str, dst_ip: str):
        """
        DNS packet analysis.
        
        Detects:
        - Unusually long domain names (DNS tunneling)
        - High query volume (possible DGA malware)
        - Suspicious query types (ANY queries — used in amplification attacks)
        - Queries to known sinkholed domains
        - NXDOMAIN storms (DGA behavior: thousands of failed lookups)
        """
        dns = pkt[DNS]
        
        if dns.qr == 0:  # DNS query (not response)
            # Extract queried domain
            if dns.qdcount > 0 and dns.qd:
                try:
                    qname = dns.qd.qname.decode('utf-8', errors='replace').rstrip('.')
                    qtype = dns.qd.qtype  # 1=A, 28=AAAA, 15=MX, 255=ANY, etc.
                    
                    self.dns_queries.append({
                        'from':   src_ip,
                        'to':     dst_ip,
                        'query':  qname,
                        'type':   qtype,
                        'time':   time.time(),
                    })
                    self.dns_query_counts[qname] += 1
                    self.dns_lengths.append(len(qname))
                    
                    # ── DNS tunneling detection ──────────────────────────────
                    # Legitimate domain: avg ~20-30 chars
                    # DNS tunnel: 50-200+ chars (data encoded in subdomain)
                    # e.g., "aGVsbG8gd29ybGQ.evil.com" (base64 data in subdomain)
                    if len(qname) > 52:
                        # Check if the unusually long part is in subdomain
                        parts = qname.split('.')
                        if parts and len(parts[0]) > 30:
                            self.suspicious_dns.append(qname)
                            self.add_alert(
                                'HIGH', 'DNS_TUNNEL',
                                f'Possible DNS tunneling from {src_ip}: query length {len(qname)} chars',
                                {'src': src_ip, 'query': qname, 'length': len(qname)}
                            )
                    
                    # ── ANY query (amplification attack) ─────────────────────
                    # DNS ANY queries return all record types = large response
                    # Used in DNS amplification DDoS
                    if qtype == 255:
                        self.add_alert(
                            'MEDIUM', 'DNS_ANY_QUERY',
                            f'DNS ANY query from {src_ip} for {qname} (amplification indicator)',
                            {'src': src_ip, 'query': qname}
                        )
                    
                    # ── High query volume per domain ──────────────────────────
                    # Alert if same domain queried >50 times (beaconing behavior)
                    if self.dns_query_counts[qname] == 50:
                        # Only alert on non-whitelisted domains
                        base_domain = '.'.join(qname.rsplit('.', 2)[-2:])
                        if base_domain not in LEGITIMATE_DOMAINS:
                            self.add_alert(
                                'MEDIUM', 'DNS_BEACON',
                                f'High DNS query volume: {qname} queried 50+ times',
                                {'src': src_ip, 'domain': qname,
                                 'count': self.dns_query_counts[qname]}
                            )
                
                except Exception:
                    pass
    
    def _analyze_arp(self, pkt):
        """
        ARP spoofing / poisoning detection.
        
        WHY: ARP has no authentication. An attacker on the same LAN can send
        fake ARP replies mapping their MAC to the gateway's IP. This causes
        all traffic to be routed through the attacker (MitM).
        
        Detection: If we see the same IP claimed by multiple MACs = ARP conflict.
        """
        arp = pkt[ARP]
        
        # ARP reply (op=2): "IP address X has MAC address Y"
        if arp.op == 2:
            ip_addr = arp.psrc
            mac_addr = arp.hwsrc
            
            self.arp_table[ip_addr].add(mac_addr)
            
            # Conflict: multiple MACs claiming the same IP
            if len(self.arp_table[ip_addr]) > 1:
                conflict = {
                    'ip':   ip_addr,
                    'macs': list(self.arp_table[ip_addr]),
                }
                
                # Only alert once per IP conflict
                if ip_addr not in [c['ip'] for c in self.arp_conflicts]:
                    self.arp_conflicts.append(conflict)
                    self.add_alert(
                        'CRITICAL', 'ARP_SPOOFING',
                        f'ARP conflict for {ip_addr}: multiple MACs claiming this IP',
                        conflict
                    )
    
    def _analyze_http(self, pkt, src_ip: str, dst_ip: str):
        """
        Analyze HTTP traffic (unencrypted).
        
        Extracts: host, URI, user agent, and checks for:
        - Credentials in GET parameters (passwords in URLs — terrible practice)
        - Suspicious user agents (malware often uses generic or blank UAs)
        - C2-style beaconing patterns (regular, identical requests)
        """
        try:
            raw = bytes(pkt[Raw])
            decoded = raw.decode('utf-8', errors='ignore')
            
            # Parse basic HTTP request
            if decoded.startswith('GET') or decoded.startswith('POST') or \
               decoded.startswith('HEAD') or decoded.startswith('PUT'):
                
                lines = decoded.split('\r\n')
                request_line = lines[0] if lines else ''
                
                headers = {}
                for line in lines[1:]:
                    if ':' in line:
                        key, _, value = line.partition(':')
                        headers[key.strip().lower()] = value.strip()
                
                host = headers.get('host', dst_ip)
                user_agent = headers.get('user-agent', '')
                
                request_info = {
                    'src':          src_ip,
                    'host':         host,
                    'request':      request_line[:200],
                    'user_agent':   user_agent,
                    'time':         time.time(),
                }
                self.http_requests.append(request_info)
                
                # ── Suspicious user agent check ────────────────────────────
                # Legitimate browsers have detailed, recognizable UAs
                # Malware often uses blank, generic, or tool-like UAs
                suspicious_ua_patterns = [
                    r'^python-requests/',    # Scripted requests
                    r'^curl/',               # Command-line tool
                    r'^wget/',               # Download tool
                    r'^-$',                  # Just a dash
                    r'^$',                   # Empty
                    r'(?:nmap|nikto|sqlmap|burp|masscan|zgrab)',  # Scanner tools
                ]
                import re
                for pattern in suspicious_ua_patterns:
                    if re.match(pattern, user_agent, re.IGNORECASE):
                        self.suspicious_http.append(request_info)
                        self.add_alert(
                            'LOW', 'SUSPICIOUS_UA',
                            f'{src_ip} → {host}: Suspicious User-Agent: "{user_agent}"',
                            {'src': src_ip, 'host': host, 'user_agent': user_agent}
                        )
                        break
                
                # ── Credentials in URL ─────────────────────────────────────
                # GET /login?username=user&password=pass (very bad practice)
                if re.search(r'[?&](?:pass|password|passwd|pwd|secret)=', 
                             request_line, re.IGNORECASE):
                    self.add_alert(
                        'HIGH', 'CREDENTIALS_IN_URL',
                        f'{src_ip} → {host}: Password in GET parameter (cleartext)',
                        {'src': src_ip, 'host': host, 'request': request_line[:100]}
                    )
        
        except Exception:
            pass
    
    def get_statistics(self) -> dict:
        """Compile all statistics into a structured report."""
        
        elapsed = time.time() - self.start_time
        
        # Top talkers (by bytes transferred)
        top_senders = sorted(
            self.bytes_per_src.items(), key=lambda x: x[1], reverse=True
        )[:10]
        
        top_receivers = sorted(
            self.bytes_per_dst.items(), key=lambda x: x[1], reverse=True
        )[:10]
        
        # Top DNS queries
        top_dns = self.dns_query_counts.most_common(20)
        
        # Top connections (most packets)
        top_connections = sorted(
            [(k, len(v)) for k, v in self.connections.items()],
            key=lambda x: x[1], reverse=True
        )[:10]
        
        # Average DNS query length (tunneling indicator)
        avg_dns_length = (
            sum(self.dns_lengths) / len(self.dns_lengths) 
            if self.dns_lengths else 0
        )
        
        # Data exfiltration detection
        # Flag hosts sending more than 100MB
        potential_exfil = {
            ip: bytes_sent 
            for ip, bytes_sent in self.bytes_per_src.items()
            if bytes_sent > 100 * 1024 * 1024  # 100 MB
        }
        
        # Alert on high-volume senders not in private ranges
        for ip, bytes_sent in potential_exfil.items():
            try:
                ip_obj = ipaddress.ip_address(ip)
                if not any(ip_obj in net for net in PRIVATE_NETWORKS):
                    self.add_alert(
                        'HIGH', 'POSSIBLE_EXFIL',
                        f'{ip} sent {bytes_sent / 1024 / 1024:.1f} MB (possible exfiltration)',
                        {'src': ip, 'bytes': bytes_sent}
                    )
            except ValueError:
                pass
        
        return {
            'capture_summary': {
                'total_packets': self.total_packets,
                'elapsed_seconds': round(elapsed, 2),
                'packets_per_second': round(self.total_packets / elapsed, 1) if elapsed > 0 else 0,
                'first_packet': datetime.datetime.utcfromtimestamp(
                    self.first_packet_time).isoformat() + 'Z'
                    if self.first_packet_time else None,
                'last_packet': datetime.datetime.utcfromtimestamp(
                    self.last_packet_time).isoformat() + 'Z'
                    if self.last_packet_time else None,
            },
            'protocol_breakdown': dict(self.protocol_counts),
            'top_senders': [
                {'ip': ip, 'bytes': b, 'kb': round(b/1024, 1)} 
                for ip, b in top_senders
            ],
            'top_receivers': [
                {'ip': ip, 'bytes': b, 'kb': round(b/1024, 1)} 
                for ip, b in top_receivers
            ],
            'top_connections': [
                {
                    'src': k[0], 'dst': k[1], 'port': k[2],
                    'service': SERVICE_BANNERS.get(k[2], 'unknown'),
                    'packets': count
                }
                for k, count in top_connections
            ],
            'dns_analysis': {
                'total_queries': len(self.dns_queries),
                'unique_domains': len(self.dns_query_counts),
                'avg_query_length': round(avg_dns_length, 2),
                'suspicious_queries': self.suspicious_dns[:20],
                'top_queried_domains': [
                    {'domain': d, 'count': c} for d, c in top_dns
                ],
            },
            'arp_analysis': {
                'conflicts': self.arp_conflicts,
                'unique_arp_entries': len(self.arp_table),
            },
            'http_analysis': {
                'total_http_requests': len(self.http_requests),
                'suspicious_requests': len(self.suspicious_http),
            },
            'port_scan_detection': {
                'scan_sessions': len(self.port_scan_alerts_fired),
                'tracked_sources': len(self.port_scan_tracker),
            },
            'potential_exfiltration': {
                ip: {'bytes': b, 'mb': round(b / 1024 / 1024, 2)}
                for ip, b in potential_exfil.items()
            },
            'alerts': sorted(
                self.alerts,
                key=lambda x: ['CRITICAL', 'HIGH', 'MEDIUM', 'LOW', 'INFO'].index(x['level'])
            ),
            'alert_summary': {
                level: sum(1 for a in self.alerts if a['level'] == level)
                for level in ['CRITICAL', 'HIGH', 'MEDIUM', 'LOW', 'INFO']
            },
        }


# ── Live Capture Mode ─────────────────────────────────────────────────────────

def run_live_capture(interface: str, duration: int, output_pcap: str = None,
                     bpf_filter: str = '') -> dict:
    """
    Capture packets from a live network interface.
    
    Requires: root/administrator privileges
    """
    if not SCAPY_AVAILABLE:
        print('[!] scapy required for live capture')
        sys.exit(1)
    
    analyzer = NetworkAnalyzer()
    
    print(f'\n{"="*60}')
    print(f'  NETWORK TRAFFIC ANALYZER — LIVE CAPTURE')
    print(f'{"="*60}')
    print(f'  Interface: {interface}')
    print(f'  Duration:  {duration}s')
    print(f'  Filter:    {bpf_filter or "none (capture all)"}')
    if output_pcap:
        print(f'  Saving to: {output_pcap}')
    print(f'{"="*60}')
    print(f'\n[*] Starting capture... (Ctrl+C to stop early)\n')
    
    captured_packets = []
    stop_event = threading.Event()
    
    def packet_handler(pkt):
        captured_packets.append(pkt)
        analyzer.process_packet(pkt)
    
    def stop_after_duration():
        time.sleep(duration)
        stop_event.set()
    
    # Start stop timer
    timer = threading.Thread(target=stop_after_duration, daemon=True)
    timer.start()
    
    try:
        sniff(
            iface=interface,
            prn=packet_handler,
            filter=bpf_filter,
            stop_filter=lambda _: stop_event.is_set(),
            store=False,
        )
    except KeyboardInterrupt:
        print('\n[*] Capture interrupted by user')
    
    # Save PCAP if requested
    if output_pcap and captured_packets:
        wrpcap(output_pcap, captured_packets)
        print(f'\n[+] PCAP saved: {output_pcap}')
    
    return analyzer.get_statistics()


# ── PCAP Analysis Mode ────────────────────────────────────────────────────────

def analyze_pcap(filepath: str) -> dict:
    """
    Parse and analyze an existing .pcap or .pcapng file.
    
    Great for:
    - Analyzing Wireshark captures
    - Processing packet captures from network taps or IDS/IPS
    - Offline forensics of network incidents
    """
    if not SCAPY_AVAILABLE:
        print('[!] scapy required for PCAP analysis')
        sys.exit(1)
    
    print(f'\n{"="*60}')
    print(f'  NETWORK TRAFFIC ANALYZER — PCAP ANALYSIS')
    print(f'{"="*60}')
    print(f'  File: {filepath}')
    print(f'{"="*60}')
    
    if not os.path.exists(filepath):
        print(f'[!] File not found: {filepath}')
        sys.exit(1)
    
    print('\n[*] Loading PCAP file...')
    try:
        packets = rdpcap(filepath)
    except Exception as e:
        print(f'[!] Failed to read PCAP: {e}')
        sys.exit(1)
    
    print(f'    Loaded {len(packets):,} packets')
    
    analyzer = NetworkAnalyzer()
    
    print('[*] Processing packets...\n')
    for i, pkt in enumerate(packets):
        analyzer.process_packet(pkt)
        
        # Progress indicator every 10,000 packets
        if (i + 1) % 10000 == 0:
            print(f'    Processed {i+1:,}/{len(packets):,} packets...')
    
    return analyzer.get_statistics()


# ── Report Output ──────────────────────────────────────────────────────────────

def print_analysis_report(stats: dict):
    """Print a human-readable analysis report."""
    
    print(f'\n{"="*60}')
    print(f'  NETWORK ANALYSIS REPORT')
    print(f'{"="*60}')
    
    # Capture summary
    summary = stats.get('capture_summary', {})
    print(f"\n  📊 CAPTURE SUMMARY")
    print(f"     Total Packets:  {summary.get('total_packets', 0):,}")
    print(f"     Duration:       {summary.get('elapsed_seconds', 0)}s")
    print(f"     Packets/sec:    {summary.get('packets_per_second', 0)}")
    
    # Protocol breakdown
    print(f"\n  📡 PROTOCOL BREAKDOWN")
    for proto, count in sorted(stats.get('protocol_breakdown', {}).items(), 
                                key=lambda x: x[1], reverse=True):
        print(f"     {proto:<10s}: {count:,}")
    
    # Alert summary
    alert_summary = stats.get('alert_summary', {})
    total_alerts = sum(alert_summary.values())
    print(f"\n  🚨 ALERTS ({total_alerts} total)")
    for level in ['CRITICAL', 'HIGH', 'MEDIUM', 'LOW', 'INFO']:
        count = alert_summary.get(level, 0)
        if count > 0:
            icons = {'CRITICAL': '🔴', 'HIGH': '🟠', 'MEDIUM': '🟡', 'LOW': '🔵', 'INFO': '⚪'}
            print(f"     {icons[level]} {level:<10s}: {count}")
    
    # Top talkers
    print(f"\n  📤 TOP SENDERS (by bytes)")
    for entry in stats.get('top_senders', [])[:5]:
        print(f"     {entry['ip']:<20s}: {entry['kb']:>10.1f} KB")
    
    # DNS analysis
    dns = stats.get('dns_analysis', {})
    print(f"\n  🔍 DNS ANALYSIS")
    print(f"     Total queries:    {dns.get('total_queries', 0):,}")
    print(f"     Unique domains:   {dns.get('unique_domains', 0):,}")
    print(f"     Avg query length: {dns.get('avg_query_length', 0)} chars")
    if dns.get('suspicious_queries'):
        print(f"     Suspicious:       {len(dns['suspicious_queries'])} queries flagged")
    
    # Top connections
    print(f"\n  🔗 TOP CONNECTIONS")
    for conn in stats.get('top_connections', [])[:5]:
        service = conn.get('service', 'unknown')
        print(f"     {conn['src']} → {conn['dst']}:{conn['port']} ({service}) — {conn['packets']} pkts")
    
    # Detailed alerts
    alerts = stats.get('alerts', [])
    if alerts:
        print(f"\n  🚨 DETAILED ALERTS")
        for alert in alerts[:20]:
            print(f"     [{alert['level']}] {alert['category']}: {alert['message']}")
    
    print(f'\n{"="*60}\n')


# ── CLI Entry Point ────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description='Network Traffic Analyzer — Live Capture & PCAP Analysis',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # Analyze existing PCAP file (no root needed):
  python network_analyzer.py --pcap capture.pcap

  # Live capture for 60 seconds:
  sudo python network_analyzer.py --interface eth0 --duration 60

  # Capture with BPF filter and save PCAP:
  sudo python network_analyzer.py --interface eth0 --duration 120 \\
    --filter "not port 443" --output capture.pcap

  # Save report to JSON:
  python network_analyzer.py --pcap capture.pcap --output-json report.json

BPF Filter Examples:
  "host 192.168.1.1"        # Only traffic to/from this IP
  "port 80 or port 443"     # Only HTTP/HTTPS
  "not icmp"                # Exclude ICMP
  "tcp and port 22"         # Only SSH

Get sample PCAPs from: https://www.malware-traffic-analysis.net/
        """
    )
    
    mode = parser.add_mutually_exclusive_group(required=True)
    mode.add_argument('--pcap', help='Analyze a PCAP file')
    mode.add_argument('--interface', '-i', help='Network interface for live capture')
    
    parser.add_argument('--duration', '-d', type=int, default=60,
                        help='Live capture duration in seconds (default: 60)')
    parser.add_argument('--filter', '-f', dest='bpf_filter', default='',
                        help='BPF filter expression')
    parser.add_argument('--output', '-o', help='Save captured packets to .pcap file')
    parser.add_argument('--output-json', help='Save analysis report to JSON file')
    
    args = parser.parse_args()
    
    if args.pcap:
        stats = analyze_pcap(args.pcap)
    else:
        stats = run_live_capture(
            interface=args.interface,
            duration=args.duration,
            output_pcap=args.output,
            bpf_filter=args.bpf_filter,
        )
    
    print_analysis_report(stats)
    
    if args.output_json:
        with open(args.output_json, 'w') as f:
            json.dump(stats, f, indent=2, default=str)
        print(f'[+] JSON report saved: {args.output_json}')
    
    # Return exit code based on critical alerts
    critical_count = stats.get('alert_summary', {}).get('CRITICAL', 0)
    high_count = stats.get('alert_summary', {}).get('HIGH', 0)
    
    if critical_count > 0:
        print(f'\n[!] {critical_count} CRITICAL alert(s) detected!')
        sys.exit(2)
    elif high_count > 0:
        print(f'\n[!] {high_count} HIGH severity alert(s) detected!')
        sys.exit(1)
    else:
        sys.exit(0)


if __name__ == '__main__':
    main()
